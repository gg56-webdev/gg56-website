---
import Layout from "@/layouts/Layout.astro";
import { getLocaleParams } from "@/utils";
export function getStaticPaths() {
  return getLocaleParams();
}
---

<Layout>
  <section
    id="hero"
    aria-labelledby="hero-title"
    class="relative grid *:[grid-area:1/1]"
  >
    <h1 class="sr-only">GG56</h1>
    <div id="controls" class="absolute end-0 top-0 z-20 flex gap-2"></div>
    <video
      src="https://videos.pexels.com/video-files/1851190/1851190-uhd_2560_1440_25fps.mp4"
      autoplay
      loop
      muted
      playsinline
      class="h-[calc(100vh-56px)] w-full object-cover"></video>
    <div class="mx-auto w-full max-w-(--breakpoint-lg) self-end p-8 md:p-12">
      <div
        class="fade text-neutral-content grid pb-4 text-xl font-bold text-balance text-shadow-md *:[grid-area:1/1] sm:text-2xl md:pb-12 md:text-4xl"
      >
        <p>
          새로운 금융시장<br /><br />
          우리가 혁신을 선도 하겠습니다.
        </p>
        <p>
          IT와 블록체인으로 다져진 기업<br /><br />
          이제, <span class="text-blue-400">암호화폐거래소</span>와<br />
          <span class="ps-[4ch] text-green-400">디지털뱅크</span> 사업을 시작합니다.
        </p>
        <p>
          글로벌을 향한,<br /><br />
          혁신적인 금융의 새 지평을<br />
          열겠습니다.
        </p>
        <p>
          당신 곁에서,<br />
          당신의 손안에서,<br />
          가장 신뢰하며 유익한<br /><br />
          당신의 파트너가 되겠습니다.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .fade > * {
    opacity: 0;
    animation: fadeInOut 20s ease-out infinite;
  }

  .fade > :nth-child(2) {
    animation-delay: 5s;
  }
  .fade > :nth-child(3) {
    animation-delay: 10s;
  }
  .fade > :nth-child(4) {
    animation-delay: 15s;
  }

  @keyframes fadeInOut {
    0% {
      translate: 5%;
    }
    5%,
    20% {
      translate: 0;
      opacity: 1;
    }
    25% {
      translate: -5%;
      opacity: 0;
    }
  }
</style>

<script>
  const links = [
    "https://videos.pexels.com/video-files/1851190/1851190-uhd_2560_1440_25fps.mp4",
    "https://www.pexels.com/download/video/29938300/",
    "https://www.pexels.com/download/video/16046512/",
    "https://www.pexels.com/download/video/31251625/",
    "https://www.pexels.com/download/video/7855643/",
    "https://www.pexels.com/download/video/31251627/",
    "https://www.pexels.com/download/video/30073809/",
    "https://videos.pexels.com/video-files/10343918/10343918-hd_1920_1080_24fps.mp4",
    "https://videos.pexels.com/video-files/5090509/5090509-uhd_2560_1440_30fps.mp4",
  ];

  const $controls = document.getElementById("controls")!;
  const $video = document.querySelector("video")!;
  links.forEach((link, i) => {
    const $btn = document.createElement("button");
    $btn.className = "btn btn-neutral btn-sm";
    $btn.textContent = `${i + 1}`;
    $btn.addEventListener("click", () => {
      $video.src = link;
      $video.play();
    });
    $controls.appendChild($btn);
  });
</script>

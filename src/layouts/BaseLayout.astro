---
import BaseHead from "@/components/BaseHead.astro";
import "@/style.css";
import type { ComponentProps } from "astro/types";

type Props = ComponentProps<typeof BaseHead>;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...Astro.props} />
    <slot name="head" />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
